{
  "name": "phoenix-perp-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:worker:ws": "tsx watch src/workers/ws.ts",
    "dev:worker:alert": "tsx watch src/workers/alert.ts",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/main.js",
    "start:worker:ws": "node dist/workers/ws.js",
    "start:worker:alert": "node dist/workers/alert.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check": "biome check ./src",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@ellipsis-labs/rise": "^0.4.9",
    "@fastify/cors": "^10.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@grammyjs/parse-mode": "^2.3.0",
    "@privy-io/server-auth": "^1.20.0",
    "@resvg/resvg-js": "^2.6.2",
    "@solana/kit": "^6.9.0",
    "@solana/signers": "^6.9.0",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "bullmq": "^5.34.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "grammy": "^1.31.0",
    "ioredis": "^5.4.1",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "satori": "^0.10.14",
    "sharp": "^0.33.5",
    "ws": "^8.20.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  }
}
