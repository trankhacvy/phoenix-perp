NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=
# Production only: your public domain for webhook
WEBHOOK_URL=
WEBHOOK_SECRET=

# Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Phoenix / Flight
BUILDER_AUTHORITY_PUBKEY=
BUILDER_ACCESS_CODE=
BUILDER_FEE_BPS=10
PHOENIX_API_URL=https://perp-api.phoenix.trade
PHOENIX_WS_URL=wss://perp-api.phoenix.trade/v1/ws

# Feature flags
REFERRAL_ENABLED=false

# Solana RPC
HELIUS_RPC_URL=

# PostgreSQL (Coolify) — use sslmode=require in production
DATABASE_URL=postgresql://user:password@host:5432/phoenix_perp?sslmode=require

# Redis (Coolify)
REDIS_URL=redis://host:6379

# Server
PORT=3000
HOST=0.0.0.0

# Dev only: base58 secret key of your activated wallet (64 bytes, from `solana-keygen`).
# When set in NODE_ENV=development, bypasses Privy signing — no Privy call made.
# Never set this in production.
DEV_SIGNER_SECRET_KEY=
